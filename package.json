{
  "name": "node-micro-boilerplate",
  "version": "1.0.0",
  "description": "Minimal starter files to create a NodeJS app.",
  "engines": {
    "node": "^16.13.0",
    "npm": "^8.1.0"
  },
  "main": "src/index.ts",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node-dev --require dotenv/config src/index.ts",
